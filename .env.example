# ===========================================
# Konaklama Platformu - Ortam Değişkenleri
# ===========================================

# Genel
NODE_ENV=development
DOMAIN=www.evomstay.com

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=konaklama_db
POSTGRES_USER=platform_user
POSTGRES_PASSWORD=change_me_strong_password_123

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_password_123

# Elasticsearch
ELASTICSEARCH_HOST=elasticsearch
ELASTICSEARCH_PORT=9200

# MinIO (S3-uyumlu object storage)
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_minio_password_123
MINIO_BUCKET=platform-media

# JWT
JWT_SECRET=change_me_jwt_secret_256bit_key_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_jwt_refresh_secret_key
JWT_REFRESH_EXPIRES_IN=7d

# Stripe
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
STRIPE_PLATFORM_FEE_PERCENT=10

# SendGrid (Email)
SENDGRID_API_KEY=SG.xxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@example.com

# Twilio (SMS)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1234567890

# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=your-project-id

# Google Maps
GOOGLE_MAPS_API_KEY=AIzaxxxxxxxxxxxxxxxx

# Platform
PLATFORM_NAME=Konaklama
PLATFORM_URL=https://www.evomstay.com
PLATFORM_COMMISSION_PERCENT=10
ESCROW_RELEASE_HOURS=24
